# Example target repos are git-inited locally for demos; don't nest their .git
examples/**/repo/.git/
# Local-only tests (kept off the repo by request)
tests/local/
# Run artifacts (the run store) are local-only
.sembl/
examples/**/repo/.sembl/
__pycache__/
*.egg-info/
.pytest_cache/
.test-tmp/
build/
dist/
.venv/
eval/.checkpoint-*.json
eval/.result-*
eval/.fg-*
eval/.suite-*

# Theia IDE workspace: installed/generated, not source
ide/node_modules/
ide/package-lock.json
ide/*/node_modules/
ide/*/lib/
ide/browser-app/src-gen/
ide/browser-app/gen-webpack*
ide/browser-app/plugins/
